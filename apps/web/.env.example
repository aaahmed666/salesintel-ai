# ============================================================================
# Frontend (apps/web/.env.local) — Sales Intelligence Web
# ============================================================================

# Point straight at the FastAPI backend's versioned auth mount.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

NEXT_PUBLIC_APP_ENV=development

# IMPORTANT: set to false to hit the REAL backend instead of in-memory mocks.
NEXT_PUBLIC_ENABLE_MOCKS=false

# Public Supabase creds — only needed if you do the Google OAuth code exchange
# client-side. With the backend-driven flow used here they are optional.
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
